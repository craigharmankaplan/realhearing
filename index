    btn.classList.toggle('active', btn.textContent.toLowerCase().includes(mode === 'free' ? 'free' : 'guided'));
  });
  document.getElementById('scenarioCard').style.display = mode === 'scenario' ? '' : 'none';
  if (mode === 'scenario') buildScenarioPanel();
}

// ============ Snackbar ============
function showSnackbar(text) {
  const bar = document.getElementById('snackbar');
  document.getElementById('snackbarText').textContent = text;
  bar.classList.add('visible');
  clearTimeout(bar._timeout);
  bar._timeout = setTimeout(() => bar.classList.remove('visible'), 3000);
}

// ============ Render ============
function render() {
  drawGrid();
  updateThresholdTable();
  updateClassification();
}

// ============ Keyboard ============
document.addEventListener('keydown', (e) => {
  if (e.key === '1') selectTool('air-right');
  if (e.key === '2') selectTool('air-left');
  if (e.key === '3') selectTool('bone-right');
  if (e.key === '4') selectTool('bone-left');
  if (e.key === 'z' && (e.ctrlKey || e.metaKey)) { e.preventDefault(); undoLast(); }
  if (e.key === 'Escape') resetAll();
});

// ============ Init ============
drawGrid();
initInteraction();
updateThresholdTable();
</script>
</body>
</html>
