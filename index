function buildScenarioPanel() {
  const body = document.getElementById('scenarioBody');
  let html = '<p class="practice-description">Select a scenario and try to plot the correct audiogram pattern. Click "Check My Work" to see how close you are.</p>';
  for (const s of SCENARIOS) {
    html += `<button class="scenario-btn" data-id="${s.id}" onclick="loadScenario('${s.id}')">${s.name}<span class="scenario-label">${s.description.substring(0, 70)}…</span></button>`;
  }
  html += '<button class="check-btn" id="checkBtn" onclick="checkWork()" disabled>Check My Work</button>';
  html += '<div id="resultArea"></div>';
  body.innerHTML = html;
}

function loadScenario(id) {
  activeScenario = SCENARIOS.find(s => s.id === id);
  markers = [];
  undoStack = [];
  render();
  updateScenarioUI();
  document.getElementById('checkBtn').disabled = false;
}

function updateScenarioUI() {
  document.querySelectorAll('.scenario-btn').forEach(btn => {
    btn.classList.toggle('active', activeScenario && btn.dataset.id === activeScenario.id);
  });
  const resultArea = document.getElementById('resultArea');
  if (resultArea) resultArea.innerHTML = '';
}

function checkWork() {
  if (!activeScenario) return;
  const expected = activeScenario.expected;
  const tolerance = activeScenario.tolerance;
  let totalExpected = 0;
  let totalCorrect = 0;
  let feedback = [];

  for (const [type, freqMap] of Object.entries(expected)) {
    for (const [freqStr, expectedDb] of Object.entries(freqMap)) {
      const freq = parseInt(freqStr);
      totalExpected++;
      const placed = markers.find(m => m.type === type && m.freq === freq);
      if (!placed) {
        feedback.push(`Missing: ${typeLabel(type)} at ${freq} Hz (expected ~${expectedDb} dB)`);
      } else if (Math.abs(placed.db - expectedDb) > tolerance) {
        feedback.push(`${typeLabel(type)} at ${freq} Hz: you placed ${placed.db} dB, expected ~${expectedDb} dB`);
      } else {
        totalCorrect++;
      }
    }
  }

  const pct = Math.round((totalCorrect / totalExpected) * 100);
  const pass = pct >= 75;
  const resultArea = document.getElementById('resultArea');
  let html = `<div class="result-card ${pass ? 'pass' : 'fail'}">`;
  html += `<strong>${pass ? '✓' : '✗'} ${pct}% correct (${totalCorrect}/${totalExpected})</strong>`;
  if (feedback.length > 0 && feedback.length <= 6) {
    html += feedback.join('<br>');
  } else if (feedback.length > 6) {
    html += feedback.slice(0, 5).join('<br>') + `<br>…and ${feedback.length - 5} more`;
  } else {
    html += 'Great work! Your audiogram matches the expected pattern.';
  }
  html += '</div>';
  resultArea.innerHTML = html;
}

function typeLabel(type) {
  const labels = { 'air-right': 'Right AC (O)', 'air-left': 'Left AC (X)', 'bone-right': 'Right BC (<)', 'bone-left': 'Left BC (>)' };
  return labels[type] || type;
}

